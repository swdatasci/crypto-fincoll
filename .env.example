# FinColl V7 Service Configuration
# Copy this to .env and fill in your actual values

# ============================================================================
# Service Config
# ============================================================================
FINCOLL_HOST=0.0.0.0
FINCOLL_PORT=8001
FINCOLL_DEBUG=false
FINCOLL_LOG_LEVEL=INFO
FINCOLL_ENV=development  # development, staging, production

# ============================================================================
# FinVec V7 Model Configuration (NEW)
# ============================================================================
# Path to FinVec V7 model checkpoint (relative or absolute)
FINVEC_MODEL_PATH=../finvec/checkpoints/checkpoint_step_50000.pt
FINVEC_MODEL_VERSION=v7-epoch-200
FINVEC_DEVICE=cuda  # cuda, cpu, or cuda:0, cuda:1, etc.

# Feature dimensions (must match model training)
FINVEC_FEATURE_DIM=336  # V7: 336D (V6: 335D)
FINVEC_EMBED_DIM=512    # Model embedding dimension
FINVEC_NUM_LAYERS=12
FINVEC_NUM_HEADS=8

# Feature cache directory (for backtesting)
FEATURE_CACHE_DIR=./cache/features
CACHE_MAX_SIZE_GB=50
CACHE_TTL_HOURS=168  # 7 days

# Credentials Path (do NOT commit actual credentials!)
CREDENTIALS_DIR=/home/rford/caelum/ss

# Data Sources
# TradeStation OAuth (stored in CREDENTIALS_DIR/.tradestation_token.json)
TRADESTATION_API_URL=https://api.tradestation.com/v3

# Alpha Vantage (stored in CREDENTIALS_DIR/.alpha_vantage_credentials.json)
# Get free API key at: https://www.alphavantage.co/support/#api-key

# SenVec Service
SENVEC_API_URL=http://10.32.3.27:8000
SENVEC_ENABLED=true

# Storage
REDIS_HOST=10.255.255.254
REDIS_PORT=6379
REDIS_DB=3

POSTGRES_HOST=10.255.255.254
POSTGRES_PORT=5432
POSTGRES_DB=fincoll
POSTGRES_USER=caelum
# POSTGRES_PASSWORD=<set-in-.env>

# Caching Strategy
CACHE_HOT_TTL=300        # 5 min for hot data (inference)
CACHE_WARM_TTL=3600      # 1 hour for warm data
CACHE_COLD_PERSISTENT=1  # PostgreSQL keeps forever

# Rate Limiting
TRADESTATION_RATE_LIMIT=120    # requests/min
ALPHAVANTAGE_RATE_LIMIT=5      # requests/min (free tier)
SENVEC_RATE_LIMIT=1000         # requests/min (local)

# API Authentication
# FINCOLL_API_KEY=<generate-secure-key>  # For client authentication
